---
import { Image } from "astro:assets";
import type { StoryEntry } from "@/types";

interface Props {
  entry: StoryEntry;
}

const { entry }: Props = Astro.props;

const { title, cover, coverAlt, audio } = entry.data;
---

<div class="mt-2">
  {
    cover && (
      <div class="mb-8 glass rounded-lg intersect:animate-fadeDown opacity-0 intersect-no-queue">
        <Image
          class="w-full rounded-lg"
          src={cover}
          alt={coverAlt || `Cover image for ${title}`}
          height={500}
          width={1200}
          loading="eager"
        />
      </div>
    )
  }
</div>

{
  audio && (
    <div class="mb-6">
      <audio
        controls
        preload="metadata"
        src={audio}
        style="width: 100%;"
      >
        <source src={audio} type="audio/mpeg" />
        Your browser does not support the audio element.
      </audio>
      <p class="mt-2 text-sm">
        <a href={audio}>If audio does not start, open the MP3 directly</a>
      </p>
    </div>
  )
}
